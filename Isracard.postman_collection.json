  "item": [
    {
      "name": "auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var data = pm.response.json();\r",
              "pm.environment.set(\"token\", data.payload.token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n\t\"captcha\": null,\r\n\t\"email\": \"{{email}}\",\r\n\t\"passwordOpen\": \"{{password}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v2/auth",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v2",
            "auth"
          ]
        }
      },
      "response": []
    },
    {
      "name": "payment link",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var data = pm.response.json();\r",
              "pm.environment.set(\"_sale_url\", data.payload.sale_url);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n\t\"currency\": \"ILS\",\r\n\t\"installments\": 1,\r\n\t\"payment_method\": \"multi\",\r\n\t\"paymentType\": \"template\",\r\n\t\"price\": {{price}},\r\n\t\"product_name\": \"{{name}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/api/v2/sales",
          "host": [
            "{{url}}"
          ],
          "path": [
            "api",
            "v2",
            "sales"
          ]
        }
      },
      "response": []
    }
  ],
